# ─────────────────────────────────────────────────────────────
# Better Auth — environment template
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.example` is committed.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_NAME=Dobaeni
# Production: https://your-app.vercel.app  |  Dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth
# Generate a new secret with:  openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-32-char-min-random-secret
# Production: https://your-app.vercel.app  |  Dev: http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Database
# Dev: local docker-compose  |  Prod: Neon / Supabase hosted URL
DATABASE_URL=postgresql://dobaeni:dobaeni@localhost:5432/dobaeni?schema=public

# Trusted origins (comma-separated, optional extra)
TRUSTED_ORIGINS=http://localhost:3000

# ── OAuth providers (OPTIONAL in dev) ──
# Leave blank to disable a provider. Better Auth only enables a
# provider when BOTH client id AND secret are present.
# IMPORTANT: In production, update redirect URIs in each provider's console
# to point to your Vercel domain (e.g. https://your-app.vercel.app/...).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email (Resend) ──
# Get a key at https://resend.com (free tier: 100 emails/day, 3000/month).
RESEND_API_KEY=
# Verified sender — in production this MUST be from a domain you verified in Resend.
# Format: "Dobaeni <noreply@yourdomain.com>"
# In dev with DEV_EMAIL_OVERRIDE set, the from address is overridden to onboarding@resend.dev.
EMAIL_FROM=Dobaeni <onboarding@resend.dev>
# DEV ONLY: redirect ALL auth emails to this address (e.g. a temp inbox).
# Ignored in production (NODE_ENV=production) — emails go to the real recipient.
DEV_EMAIL_OVERRIDE=

# ── Chat agent (Google ADK TypeScript, runs inside Next.js) ──
# Same OpenCode Zen key the old Python server used.
OPENCODE_API_KEY=
# OpenCode Zen base URL (optional — defaults to https://opencode.ai/zen/v1).
# OPENCODE_API_BASE=https://opencode.ai/zen/v1
# Read-only Postgres for the catalog tools. Prefer a dedicated
# read-only role in production. On Vercel this MUST be a hosted
# DB (Neon/Supabase/etc.), never localhost.
AGENT_DATABASE_URL=postgresql://dobaeni:dobaeni@localhost:5432/dobaeni
# Base URL used to build product/brand links in chat replies.
# REQUIRED in production — a missing value throws instead of falling back to localhost.
SITE_BASE_URL=http://localhost:3000

# ── Test script (scripts/testAgent.ts, dev only) ──
# Base URL the test harness POSTs to. Defaults to http://localhost:3000 in dev.
# TEST_BASE_URL=http://localhost:3000

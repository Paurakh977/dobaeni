# ─────────────────────────────────────────────────────────────
# Better Auth — environment template
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.example` is committed.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_NAME=Dobaeni
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth
# Generate a new secret with:  openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-32-char-min-random-secret
BETTER_AUTH_URL=http://localhost:3000

# Database (matches docker-compose.yml)
DATABASE_URL=postgresql://dobaeni:dobaeni@localhost:5432/dobaeni?schema=public

# Trusted origins (comma-separated, optional extra)
TRUSTED_ORIGINS=http://localhost:3000

# ── OAuth providers (OPTIONAL in dev) ──
# Leave blank to disable a provider. Better Auth only enables a
# provider when BOTH client id AND secret are present.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email (Resend) ──
# Get a key at https://resend.com  (free dev tier works).
RESEND_API_KEY=
# Verified sender. With the dev override below, real emails are
# redirected to your inbox so nothing is sent to real users.
EMAIL_FROM=Dobaeni <onboarding@resend.dev>
# DEV ONLY: redirect ALL auth emails to this address (e.g. a temp inbox).
# Leave blank to send to the real user email.
DEV_EMAIL_OVERRIDE=
